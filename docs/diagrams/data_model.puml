@startuml data_model

skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam shadowing false
skinparam linetype ortho

skinparam entity {
    BackgroundColor #F9F9F9
    BorderColor #333333
}

' Dimensions
entity "dim_date" {
    * date_key : INTEGER <<PK>>
    --
    date : DATE
    year : INTEGER
    month : INTEGER
    month_name : VARCHAR
    day : INTEGER
    quarter : INTEGER
    week_day : INTEGER
    weekday_name : VARCHAR
    is_weekend : BOOLEAN
    season : VARCHAR
}

entity "dim_time" {
    * time_key : INTEGER <<PK>>
    --
    hour : INTEGER
    is_night : BOOLEAN
    day_period : VARCHAR
    am_pm : VARCHAR
}

entity "dim_flights" {
    * flight_key : VARCHAR(32) <<PK>>
    --
    flight_key_with_date : VARCHAR(32) <<AK>>
    flight_number : VARCHAR
    origin : VARCHAR
    destination : VARCHAR
    date : INTEGER <<FK>>
    hour_of_departure : INTEGER <<FK>>
    time : TIME
}

entity "dim_products" {
    * product_key : VARCHAR(32) <<PK>>
    --
    item_id : VARCHAR
    status : VARCHAR
    category : VARCHAR
    is_food : BOOLEAN
    item_type : VARCHAR
    price : NUMERIC
}

entity "dim_sessions" {
    * sales_session_id : VARCHAR(32) <<PK>>
    --
    is_offline_mode : BOOLEAN
}

entity "dim_card" {
    * card_number_prefix : VARCHAR <<PK>>
    --
    source_card_type : VARCHAR
    card_brand : VARCHAR
    reference_card_type : VARCHAR
    card_category : VARCHAR
    card_issuer : VARCHAR
    issuer_country : VARCHAR
}

' Bridge Tables
entity "bridge_flight_load" {
    * flight_key : VARCHAR(32) <<PK,FK>>
    --
    line_id : VARCHAR
    load_id : VARCHAR
}

' Facts
entity "fact_sales" {
    * sale_transaction_key : VARCHAR(32) <<PK>>
    --
    flight_key : VARCHAR(32) <<FK>>
    sales_session_id : VARCHAR(32) <<FK>>
    product_key : VARCHAR(32) <<FK>>
    load_id : VARCHAR
    slip_id : UUID
    sales_type : VARCHAR
    currency : VARCHAR
    sold_quantity : INTEGER
    purchase_amount : NUMERIC
    discount_amount : NUMERIC
}

entity "fact_payments" {
    * payment_transaction_key : VARCHAR(32) <<PK>>
    --
    flight_key : VARCHAR(32) <<FK>>
    sales_session_id : VARCHAR(32) <<FK>>
    card_number_prefix : VARCHAR <<FK>>
    load_id : VARCHAR
    slip_id : UUID
    sales_type : VARCHAR
    payment_type : VARCHAR
    purchase_amount_main : NUMERIC
}

entity "fact_pax" {
    * passenger_count_key : VARCHAR(32) <<PK>>
    --
    flight_key : VARCHAR(32) <<FK>>
    travel_class : VARCHAR
    number_of_passengers : INTEGER
}

entity "fact_wastage" {
    * wastage_record_key : VARCHAR(32) <<PK>>
    --
    flight_key_with_date : VARCHAR(32) <<FK>>
    product_key : VARCHAR(32) <<FK>>
    load_id : VARCHAR
    load_quantity : INTEGER
    sold_quantity : INTEGER
    wastage_quantity : INTEGER
    fresh_wastage_quantity : INTEGER
}

entity "fact_items_load" {
    * item_load_key : VARCHAR(32) <<PK>>
    --
    flight_key : VARCHAR(32) <<FK>>
    product_key : VARCHAR(32) <<FK>>
    load_id : VARCHAR
    total_loaded_quantity : INTEGER
    potential_error : VARCHAR
}

' Dimension Relationships
dim_date ||--o{ dim_flights
dim_time ||--o{ dim_flights

' Dimension to Fact Relationships
dim_flights ||--o{ fact_sales
dim_flights ||--o{ fact_payments
dim_flights ||--o{ fact_pax
dim_flights ||--o{ fact_wastage
dim_flights ||--o{ fact_items_load
dim_flights ||--|| bridge_flight_load

dim_sessions ||--o{ fact_sales
dim_sessions ||--o{ fact_payments

dim_products ||--o{ fact_sales
dim_products ||--o{ fact_wastage
dim_products ||--o{ fact_items_load

dim_card ||--o{ fact_payments

@enduml
